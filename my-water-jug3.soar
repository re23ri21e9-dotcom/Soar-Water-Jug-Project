sp {water-jug*rewater
   (state <s> ^name water-pro
	      ^memory-operator <memo>
	      ^operator <o> +
	      ^jug <xnow>
	      ^jug <ynow>
	      ^jug <znow>)
   (<memo> ^xcontents <xcon>
	   ^ycontents <ycon>
	   ^zcontents <zcon>)
   (<xnow> ^volume 5
	   ^contents <xcon>)
   (<ynow> ^volume 4
	   ^contents <ycon>)
   (<znow> ^volume 3
	   ^contents <zcon>)
-->
   (<s>  ^operator <o> <)
}